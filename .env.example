# Server settings
PORT=3000
DEV_MODE=true

# Official event start date (YYYY-MM-DD). Drives consistency/streak/breaks
# calculations, the mandatory-Strava messaging, and the dev simulator's
# default activity date.
EVENT_START_DATE=2026-07-26

# Database connection (e.g. Supabase Postgres connection URI)
# If left commented or empty, the app will fall back to local SQLite database (database/strides.db)
# DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Strava API credentials
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Optional override. If not set, redirect_uri will be generated dynamically based on client hostname
# STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# Strava webhook subscription. Any string you choose — Strava echoes it back
# during subscription validation so you know the request is genuinely from them.
STRAVA_WEBHOOK_VERIFY_TOKEN=choose_a_random_secret_string

# Resend (https://resend.com) — sends the Forgot Password OTP email.
# If RESEND_API_KEY is left empty, the OTP is logged to the server console
# instead of being emailed (useful for local dev without a Resend account).
RESEND_API_KEY=your_resend_api_key
# Sandbox sender that works without verifying a domain — but can only deliver
# to the email address on your own Resend account until you verify a domain.
RESEND_FROM_EMAIL=Strides <onboarding@resend.dev>

# How often (in seconds) the dashboard polls for new activity/streak data
# while the Athlete Dashboard tab is open. Webhooks update the database
# instantly; this just controls how quickly the frontend picks it up.
DASHBOARD_POLL_INTERVAL_SECONDS=15

# SMTP Email Configuration (Nodemailer)
# If left empty, emails will be logged to console and visible in the Dev Dashboard simulator
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Strides Event" <no-reply@strides-event.com>
