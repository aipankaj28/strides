# Server settings
PORT=3000
DEV_MODE=true

# Database connection (e.g. Supabase Postgres connection URI)
# If left commented or empty, the app will fall back to local SQLite database (database/strides.db)
# DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Strava API credentials
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Optional override. If not set, redirect_uri will be generated dynamically based on client hostname
# STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# Strava webhook subscription. Any string you choose — Strava echoes it back
# during subscription validation so you know the request is genuinely from them.
STRAVA_WEBHOOK_VERIFY_TOKEN=choose_a_random_secret_string

# SMTP Email Configuration (Nodemailer)
# If left empty, emails will be logged to console and visible in the Dev Dashboard simulator
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Strides Event" <no-reply@strides-event.com>
